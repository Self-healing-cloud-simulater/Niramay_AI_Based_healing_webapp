# Niramay Backend Configuration
# Copy this file to .env and adjust values as needed

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ (Stage 1 — log ingestion from Component C)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=component-c-logs

# OpenSearch (permanent storage)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# Detection Thresholds
DETECTION_LATENCY_THRESHOLD_MS=300.0
DETECTION_ANOMALY_THRESHOLD=0.4
DETECTION_ANOMALY_SCORE_THRESHOLD=3

# Stage 2 — Rate-Based Engine (Redis-backed)
RATE_BASED_ERROR_THRESHOLD=5
RATE_BASED_WINDOW_SECONDS=60

# Stage 2 — Silence Detection Engine (Redis-backed)
SILENCE_THRESHOLD_SECONDS=120
SILENCE_CHECK_INTERVAL_SECONDS=30

# Stage 2 — Baseline Anomaly Engine (Redis-backed)
BASELINE_DEVIATION_FACTOR=2.0
BASELINE_MIN_SAMPLES=20

# Traffic Generator
TRAFFIC_GENERATOR_ENABLED=true
TRAFFIC_GENERATOR_INTERVAL_MS=2000

# LLM Settings
OLLAMA_MODEL=llama3.2

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
