# Niramay Self-Healing Platform Configuration

# --- Core Platform Settings ---
PROJECT_NAME="Niramay Self-Healing Platform"
VERSION="1.0.0"
DEBUG=True
LOG_LEVEL=INFO

# --- Storage Layer ---
# Redis is used for real-time stream processing and dashboard state
REDIS_URL="redis://localhost:6379"

# PostgreSQL is used for long-term historical audit logs and RCA recording
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/niramay_db"

# --- Detection Layer ---
# Latency threshold for anomaly triggering (milliseconds)
DETECTION_LATENCY_THRESHOLD_MS=300

# Scoring Weights (Must sum to ~1.0)
DETECTION_WEIGHT_LATENCY=0.4
DETECTION_WEIGHT_STATUS=0.4
DETECTION_WEIGHT_FAILURE=0.2

# Normalized Anomaly Threshold (0.0 to 1.0)
# Transactions scoring above this will trigger the healing pipeline
DETECTION_ANOMALY_THRESHOLD=0.5

# --- Causal Engine (AI Integration) ---
# Enable/Disable LLM integration for RCA
ENABLE_AI_CAUSAL=True

# Ollama API Endpoint (Local LLaMA3)
OLLAMA_URL="http://localhost:11434/api/generate"
OLLAMA_MODEL="llama3"

# --- Healing Engine ---
# Enable/Disable automated healing actions
HEALING_ENABLED=True

# --- Traffic Generator ---
# Enable/Disable synthetic traffic generation for demonstration
TRAFFIC_GENERATOR_ENABLED=True
TRAFFIC_GENERATOR_INTERVAL_MS=2000

# --- External Dashboard URLs (used for deep-links; set on the frontend via VITE_ vars) ---
GRAFANA_URL=http://localhost:3001
OPENSEARCH_DASHBOARDS_URL=http://localhost:5601
