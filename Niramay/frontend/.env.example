# Niramay Frontend Environment Variables
# Copy to .env and set values for your environment.
# NEVER commit .env to git.

# OpenSearch Dashboards base URL (for deep-links in LogsPanel, ArtifactCards, SearchPanel)
VITE_OPENSEARCH_DASHBOARDS_URL=http://localhost:5601

# Grafana base URL (for iframe embedding in the Healing panel area)
VITE_GRAFANA_URL=http://localhost:3001
