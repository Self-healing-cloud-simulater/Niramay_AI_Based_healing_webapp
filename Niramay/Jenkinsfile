// =============================================================================
// Jenkinsfile — Niramay + Crave Integration Test Pipeline
// =============================================================================
//
// Assumptions
// -----------
// - Jenkins agent is on the same Docker host as Crave + Niramay
// - All containers share Docker network: selfhealing-network
// - Container names: niramay-backend (port 8000), crave-backend (port 8000)
// - Jenkins agent is Linux (the Docker host running the containers)
//   For local Windows runs use pytest directly, not this Jenkinsfile.
//
// Required Jenkins credentials
// ----------------------------
// CRAVE_DEV_TOKEN_CRED — Secret Text credential with the Crave developer JWT
//
// =============================================================================

pipeline {
    agent any   // use whatever agent is configured; must reach selfhealing-network

    // -------------------------------------------------------------------------
    // Pipeline-level parameters
    // -------------------------------------------------------------------------
    parameters {
        string(name: 'TRAFFIC_BURST_COUNT',           defaultValue: '20',
               description: 'Crave HTTP requests per traffic burst')
        string(name: 'LOG_PROPAGATION_SECONDS',       defaultValue: '25',
               description: 'Wait for Crave logs to appear in Niramay Redis')
        string(name: 'ANOMALY_PROPAGATION_SECONDS',   defaultValue: '20',
               description: 'Wait for Detection Worker to process logs')
        string(name: 'ANALYSER_PROPAGATION_SECONDS',  defaultValue: '20',
               description: 'Wait for Analyser Worker to produce incident reports')
        string(name: 'DISPATCHER_PROPAGATION_SECONDS',defaultValue: '15',
               description: 'Wait for Dispatcher Worker to record healing actions')
        string(name: 'POLL_MAX_RETRIES',              defaultValue: '10',
               description: 'Max polling attempts per pipeline stage check')
        string(name: 'POLL_INTERVAL_SECONDS',         defaultValue: '3',
               description: 'Seconds between polling attempts')
        booleanParam(name: 'ENABLE_HEALING', defaultValue: false,
               description: 'Enable Niramay healing execution (healing:enabled=1). ' +
                            'WARNING: RestartServiceStrategy may restart crave-backend.')
    }

    // -------------------------------------------------------------------------
    // Environment — container URLs use Docker network hostnames
    // FIX: was using Python os.environ.get() syntax which is invalid Groovy
    // FIX: CRAVE_DEV_TOKEN loaded from Jenkins credentials store, not hardcoded
    // -------------------------------------------------------------------------
    environment {
        BASE_URL                     = 'http://niramay-backend:8000'
        CRAVE_URL                    = 'http://crave-backend:8000'
        // Load the developer JWT from Jenkins Secret Text credential
        CRAVE_DEV_TOKEN              = credentials('CRAVE_DEV_TOKEN_CRED')
        // Timing constants forwarded from build parameters
        TRAFFIC_BURST_COUNT          = "${params.TRAFFIC_BURST_COUNT}"
        LOG_PROPAGATION_SECONDS      = "${params.LOG_PROPAGATION_SECONDS}"
        ANOMALY_PROPAGATION_SECONDS  = "${params.ANOMALY_PROPAGATION_SECONDS}"
        ANALYSER_PROPAGATION_SECONDS = "${params.ANALYSER_PROPAGATION_SECONDS}"
        DISPATCHER_PROPAGATION_SECONDS = "${params.DISPATCHER_PROPAGATION_SECONDS}"
        POLL_MAX_RETRIES             = "${params.POLL_MAX_RETRIES}"
        POLL_INTERVAL_SECONDS        = "${params.POLL_INTERVAL_SECONDS}"
        // Python output buffering
        PYTHONUNBUFFERED             = '1'
        // Test results directory
        TEST_RESULTS_DIR             = 'test-results'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        // =====================================================================
        // STAGE: Validate Environment
        // =====================================================================
        stage('Validate Environment') {
            steps {
                echo "=== Build Parameters ==="
                echo "BASE_URL:                    ${env.BASE_URL}"
                echo "CRAVE_URL:                   ${env.CRAVE_URL}"
                echo "TRAFFIC_BURST_COUNT:         ${env.TRAFFIC_BURST_COUNT}"
                echo "LOG_PROPAGATION_SECONDS:     ${env.LOG_PROPAGATION_SECONDS}"
                echo "ANOMALY_PROPAGATION_SECONDS: ${env.ANOMALY_PROPAGATION_SECONDS}"
                echo "ENABLE_HEALING:              ${params.ENABLE_HEALING}"

                // FIX: was 'python3' — Linux Docker agents have python3; kept as-is
                sh 'python3 --version'
                sh 'pip3 --version'
                sh "mkdir -p ${TEST_RESULTS_DIR}"
            }
        }

        // =====================================================================
        // STAGE: Install Dependencies
        // =====================================================================
        stage('Install Dependencies') {
            steps {
                echo "Installing Python test dependencies..."
                sh '''
                    pip3 install --quiet \
                       --break-system-packages \
                       pytest==8.3.0 \
                       pytest-html==4.1.1 \
                       requests==2.32.3
                '''
                sh 'pip3 show pytest requests | grep -E "^(Name|Version)"'
            }
        }

        // =====================================================================
        // STAGE: Health Check — Both Systems
        // FIX: Added sleep(5) inside retry so 12 retries = ~60s total backoff
        // =====================================================================
        stage('Health Check') {
            steps {
                echo "=== Checking Niramay backend health ==="
                // FIX: retry() alone has no delay — add explicit sleep inside
                script {
                    def niramayHealthy = false
                    for (int attempt = 1; attempt <= 12; attempt++) {
                        try {
                            def resp = sh(
                                script: "curl -sf --max-time 5 ${env.BASE_URL}/health",
                                returnStdout: true
                            ).trim()
                            echo "Niramay health (attempt ${attempt}): ${resp}"
                            if (resp.contains('"healthy"')) {
                                niramayHealthy = true
                                break
                            }
                        } catch (e) {
                            echo "Niramay not ready (attempt ${attempt}/12): ${e.message}"
                        }
                        sleep(5)
                    }
                    if (!niramayHealthy) {
                        error("Niramay health check failed after 12 attempts")
                    }
                }

                echo "=== Checking Crave backend health ==="
                script {
                    def craveHealthy = false
                    for (int attempt = 1; attempt <= 12; attempt++) {
                        try {
                            def status = sh(
                                script: "curl -sf -o /dev/null -w '%{http_code}' --max-time 5 ${env.CRAVE_URL}/health",
                                returnStdout: true
                            ).trim()
                            echo "Crave /health HTTP status (attempt ${attempt}): ${status}"
                            if (status == '200') {
                                craveHealthy = true
                                break
                            }
                        } catch (e) {
                            echo "Crave not ready (attempt ${attempt}/12): ${e.message}"
                        }
                        sleep(5)
                    }
                    if (!craveHealthy) {
                        error("Crave health check failed after 12 attempts")
                    }
                }

                echo "=== Both systems healthy — proceeding ==="
            }
        }

        // =====================================================================
        // STAGE: Start Niramay Consumer Thread
        // FIX: URL was missing /api/v1 prefix — now correct
        // =====================================================================
        stage('Start Niramay Consumer') {
            steps {
                echo "Starting Niramay RabbitMQ consumer thread (manually-started daemon)..."
                script {
                    // FIX: endpoint is /api/v1/consumer/start (not /consumer/start)
                    def resp = sh(
                        script: """
                            curl -sf -X POST \\
                                 --max-time 10 \\
                                 -w '\\n%{http_code}' \\
                                 ${env.BASE_URL}/api/v1/consumer/start
                        """,
                        returnStdout: true
                    ).trim()
                    echo "Consumer start response: ${resp}"
                    def httpCode = resp.split('\n').last()
                    // 200 = started, 409 = already running — both acceptable
                    if (httpCode != '200' && httpCode != '409') {
                        echo "WARNING: Consumer start returned ${httpCode}. Assuming already running."
                    }
                }
                sleep(3)
            }
        }

        // =====================================================================
        // STAGE: Enable Crave RabbitMQ Publishing
        // FIX: URL correct — /api/v1/failure-simulator/rabbitmq/enable (unchanged)
        // FIX: CRAVE_DEV_TOKEN now injected from credentials() not hardcoded
        // =====================================================================
        stage('Enable Crave RabbitMQ Publishing') {
            steps {
                echo "Enabling Crave to Niramay RabbitMQ log forwarding..."
                script {
                    def resp = sh(
                        script: """
                            curl -sf -X POST \\
                                 --max-time 10 \\
                                 -H "Authorization: Bearer ${env.CRAVE_DEV_TOKEN}" \\
                                 -w '\\n%{http_code}' \\
                                 ${env.CRAVE_URL}/api/v1/failure-simulator/rabbitmq/enable
                        """,
                        returnStdout: true
                    ).trim()
                    echo "RabbitMQ toggle response: ${resp}"
                    def httpCode = resp.split('\n').last()
                    if (httpCode != '200') {
                        echo "WARNING: Failed to enable RabbitMQ publishing (HTTP ${httpCode}). " +
                             "Tests that depend on the full pipeline may fail."
                        // FIX: was error() which would abort — downgrade to warning
                        // because the test suite handles a missing RabbitMQ connection
                        // with individual test SKIPs rather than a hard error.
                    }
                }
                sleep(5)
                echo "RabbitMQ publishing toggled — Crave logs will flow to Niramay"
            }
        }

        // =====================================================================
        // STAGE: Optionally Enable Niramay Healing
        // FIX: URL was missing /api/v1 prefix
        // =====================================================================
        stage('Configure Healing') {
            steps {
                script {
                    if (params.ENABLE_HEALING) {
                        echo "Enabling Niramay healing execution (ENABLE_HEALING=true)..."
                        // FIX: was /healing/toggle — correct path is /api/v1/healing/toggle
                        sh """
                            curl -sf -X POST \\
                                 --max-time 10 \\
                                 ${env.BASE_URL}/api/v1/healing/toggle
                        """
                        echo "WARNING: With healing enabled, RestartServiceStrategy may " +
                             "attempt to restart crave-backend. Ensure Docker socket is mounted."
                    } else {
                        echo "Healing disabled (default). " +
                             "Dispatcher will record status='skipped'. " +
                             "Expected per Niramay docs section 5."
                    }
                }
            }
        }

        // =====================================================================
        // STAGE: Run Integration Tests
        // FIX: was 'python3 -m pytest test_niramay_crave_integration.py' with
        //      no path — file is in backend/tests/; must specify correct path.
        // FIX: added --junit-xml for proper Jenkins test result publishing
        // =====================================================================
        stage('Run Integration Tests') {
            steps {
                echo "=== Running Niramay + Crave Integration Test Suite ==="
                sh """
                    python3 -m pytest \\
                        backend/tests/test_niramay_crave_integration.py \\
                        -v \\
                        --tb=short \\
                        --junit-xml=${TEST_RESULTS_DIR}/junit.xml \\
                        --html=${TEST_RESULTS_DIR}/report.html \\
                        --self-contained-html \\
                        -p no:cacheprovider \\
                        2>&1 | tee ${TEST_RESULTS_DIR}/pytest_output.txt
                """
            }
            post {
                always {
                    // Publish JUnit results (enables Jenkins test trend graphs)
                    junit allowEmptyResults: true,
                          testResults: "${TEST_RESULTS_DIR}/junit.xml"
                    archiveArtifacts(
                        artifacts: "${TEST_RESULTS_DIR}/**",
                        allowEmptyArchive: true
                    )
                }
            }
        }
    }

    // =========================================================================
    // POST PIPELINE — debug dump on failure, cleanup always
    // =========================================================================
    post {
        failure {
            echo "=== TEST FAILURE — Collecting Niramay diagnostic state ==="

            // FIX: all dump URLs now include /api/v1 prefix
            sh """
                echo "--- Niramay /api/v1/observation/logs ---" \\
                    > ${TEST_RESULTS_DIR}/debug_dump.txt

                curl -sf ${env.BASE_URL}/api/v1/observation/logs 2>&1 \\
                    | python3 -m json.tool 2>/dev/null \\
                    | tail -100 \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true

                echo "" >> ${TEST_RESULTS_DIR}/debug_dump.txt
                echo "--- Niramay /api/v1/detection/anomalies ---" \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt
                curl -sf ${env.BASE_URL}/api/v1/detection/anomalies 2>&1 \\
                    | python3 -m json.tool 2>/dev/null \\
                    | tail -80 \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true

                echo "" >> ${TEST_RESULTS_DIR}/debug_dump.txt
                echo "--- Niramay /api/v1/incident/reports ---" \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt
                curl -sf ${env.BASE_URL}/api/v1/incident/reports 2>&1 \\
                    | python3 -m json.tool 2>/dev/null \\
                    | tail -80 \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true

                echo "" >> ${TEST_RESULTS_DIR}/debug_dump.txt
                echo "--- Niramay /api/v1/healing/actions ---" \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt
                curl -sf ${env.BASE_URL}/api/v1/healing/actions 2>&1 \\
                    | python3 -m json.tool 2>/dev/null \\
                    | tail -60 \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true

                echo "" >> ${TEST_RESULTS_DIR}/debug_dump.txt
                echo "--- Niramay /api/v1/escalations ---" \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt
                curl -sf ${env.BASE_URL}/api/v1/escalations 2>&1 \\
                    | python3 -m json.tool 2>/dev/null \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true

                echo "" >> ${TEST_RESULTS_DIR}/debug_dump.txt
                echo "--- Niramay /api/v1/pipeline/stage ---" \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt
                curl -sf ${env.BASE_URL}/api/v1/pipeline/stage 2>&1 \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true

                echo "" >> ${TEST_RESULTS_DIR}/debug_dump.txt
                echo "--- Niramay /api/v1/stats ---" \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt
                curl -sf ${env.BASE_URL}/api/v1/stats 2>&1 \\
                    | python3 -m json.tool 2>/dev/null \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true
            """

            sh """
                echo "" >> ${TEST_RESULTS_DIR}/debug_dump.txt
                echo "--- Crave /api/v1/failure-simulator/status ---" \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt
                curl -sf \\
                     -H "Authorization: Bearer ${env.CRAVE_DEV_TOKEN}" \\
                     ${env.CRAVE_URL}/api/v1/failure-simulator/status 2>&1 \\
                    | python3 -m json.tool 2>/dev/null \\
                    >> ${TEST_RESULTS_DIR}/debug_dump.txt || true
            """

            archiveArtifacts(
                artifacts: "${TEST_RESULTS_DIR}/debug_dump.txt",
                allowEmptyArchive: true
            )
            echo "=== Debug dump written to ${TEST_RESULTS_DIR}/debug_dump.txt ==="
            sh "cat ${TEST_RESULTS_DIR}/debug_dump.txt"
        }

        always {
            echo "=== Cleanup: Resetting Crave failure scenarios ==="
            sh """
                curl -sf -X POST \\
                     --max-time 10 \\
                     -H "Authorization: Bearer ${env.CRAVE_DEV_TOKEN}" \\
                     ${env.CRAVE_URL}/api/v1/failure-simulator/reset \\
                     || echo "Warning: could not reset Crave scenarios (non-fatal)"
            """

            echo "=== Cleanup: Disabling Crave RabbitMQ publishing ==="
            sh """
                curl -sf -X POST \\
                     --max-time 10 \\
                     -H "Authorization: Bearer ${env.CRAVE_DEV_TOKEN}" \\
                     ${env.CRAVE_URL}/api/v1/failure-simulator/rabbitmq/disable \\
                     || echo "Warning: could not disable RabbitMQ toggle (non-fatal)"
            """

            echo "=== Pipeline complete ==="
        }

        success {
            echo "All Niramay + Crave integration tests passed."
        }
    }
}