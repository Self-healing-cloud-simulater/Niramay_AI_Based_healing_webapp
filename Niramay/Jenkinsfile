pipeline {
agent any

```
environment {
    BASE_URL = "http://localhost:8000/api/v1"
}

stages {

    stage('Checkout Code') {
        steps {
            checkout scm
        }
    }

    stage('Start Nirame System') {
        steps {
            echo "🚀 Starting Docker containers..."
            sh 'docker-compose up -d'
            sleep 30
        }
    }

    stage('Install Dependencies') {
        steps {
            echo "📦 Installing Python dependencies..."
            sh '''
            python -m pip install --upgrade pip
            pip install -r tests/requirements.txt
            '''
        }
    }

    stage('Run Nirame Tests') {
        steps {
            echo "🧪 Running Nirame test script..."
            sh '''
            python tests/test_nirame_pipeline.py
            '''
        }
    }

    stage('Collect Debug Info (on failure)') {
        when {
            expression { currentBuild.currentResult == 'FAILURE' }
        }
        steps {
            echo "⚠️ Collecting debug data..."

            sh '''
            echo "===== LOGS ====="
            curl http://localhost:8000/api/v1/observation/logs

            echo "===== ANOMALIES ====="
            curl http://localhost:8000/api/v1/detection/anomalies

            echo "===== REPORTS ====="
            curl http://localhost:8000/api/v1/incident/reports
            '''
        }
    }
}

post {
    always {
        echo "🧹 Cleaning up containers..."
        sh 'docker-compose down'
    }

    success {
        echo "✅ Nirame pipeline test PASSED"
    }

    failure {
        echo "❌ Nirame pipeline test FAILED"
    }
}
```

}
